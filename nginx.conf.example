# Configuration Nginx — Reverse Proxy pour Baana API
# Fichier à placer dans : /etc/nginx/sites-available/baana-api
# Puis activer : sudo ln -s /etc/nginx/sites-available/baana-api /etc/nginx/sites-enabled/
# Et recharger : sudo nginx -t && sudo systemctl reload nginx

# Redirection HTTP → HTTPS
server {
    listen 80;
    server_name api.baana.sn;

    # Certbot gère cette redirection automatiquement avec : certbot --nginx
    return 301 https://$host$request_uri;
}

# Serveur HTTPS principal
server {
    listen 443 ssl;
    server_name api.baana.sn;

    # Certificats SSL (générés par : sudo certbot --nginx -d api.baana.sn)
    ssl_certificate     /etc/letsencrypt/live/api.baana.sn/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.baana.sn/privkey.pem;

    # En-têtes de sécurité
    add_header X-Frame-Options "DENY";
    add_header X-Content-Type-Options "nosniff";
    add_header X-XSS-Protection "1; mode=block";

    # Taille max des requêtes (pour les uploads d'images)
    client_max_body_size 10M;

    # Reverse proxy vers Node.js (PM2 sur le port 5000)
    location / {
        proxy_pass         http://localhost:5000;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection 'upgrade';
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 90;
    }

    # Cache statique pour les images uploadées
    location /uploads/ {
        alias /var/www/baana/uploads/;
        expires 7d;
        add_header Cache-Control "public, no-transform";
    }
}
