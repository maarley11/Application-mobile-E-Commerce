{
  "info": {
    "_postman_id": "baana-api-phase5",
    "name": "🛒 Baana API — Phase 5 (PostgreSQL)",
    "description": "Collection complète de tests pour l'API Baana by SEN DIGITAL PULSE.\nDéveloppé par Ngary Diop — Stagiaire Backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "phone", "value": "+221770000000", "type": "string" }
  ],
  "item": [
    {
      "name": "🔐 Authentification",
      "item": [
        {
          "name": "1. Inscription (Register)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+221771234567\",\n  \"name\": \"Boutique Diallo\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api", "auth", "register"] }
          }
        },
        {
          "name": "2. Vérification OTP (Login)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const resp = pm.response.json();",
                  "if (resp.token) {",
                  "  pm.collectionVariables.set('token', resp.token);",
                  "  console.log('✅ Token JWT sauvegardé !');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+221770000000\",\n  \"otpCode\": \"1234\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/auth/verify-otp", "host": ["{{base_url}}"], "path": ["api", "auth", "verify-otp"] }
          }
        }
      ]
    },
    {
      "name": "📦 Catalogue Produits",
      "item": [
        {
          "name": "3. Tous les produits",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/products", "host": ["{{base_url}}"], "path": ["api", "products"] }
          }
        },
        {
          "name": "4. Recherche produit (ex: huile)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/products?search=huile",
              "host": ["{{base_url}}"],
              "path": ["api", "products"],
              "query": [{ "key": "search", "value": "huile" }]
            }
          }
        },
        {
          "name": "5. Filtre par catégorie",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/products?category=Ménager",
              "host": ["{{base_url}}"],
              "path": ["api", "products"],
              "query": [{ "key": "category", "value": "Ménager" }]
            }
          }
        },
        {
          "name": "6. Filtre par prix",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/products?minPrice=1000&maxPrice=5000",
              "host": ["{{base_url}}"],
              "path": ["api", "products"],
              "query": [
                { "key": "minPrice", "value": "1000" },
                { "key": "maxPrice", "value": "5000" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "🛍️ Commandes",
      "item": [
        {
          "name": "7. Passer une commande (WAVE)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentMethod\": \"WAVE\",\n  \"items\": [\n    { \"productId\": 1, \"quantity\": 5 },\n    { \"productId\": 2, \"quantity\": 1 },\n    { \"productId\": 9, \"quantity\": 2 }\n  ]\n}"
            },
            "url": { "raw": "{{base_url}}/api/orders", "host": ["{{base_url}}"], "path": ["api", "orders"] }
          }
        },
        {
          "name": "8. Historique des commandes",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/orders", "host": ["{{base_url}}"], "path": ["api", "orders"] }
          }
        },
        {
          "name": "9. Détail commande #1 (Suivi)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/orders/1", "host": ["{{base_url}}"], "path": ["api", "orders", "1"] }
          }
        }
      ]
    },
    {
      "name": "📊 Dashboard Pro",
      "item": [
        {
          "name": "10. KPIs Dashboard (totalOrders, totalSpent, savings)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/dashboard/stats", "host": ["{{base_url}}"], "path": ["api", "dashboard", "stats"] }
          }
        },
        {
          "name": "11. Graphique mensuel (Sales Chart)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/dashboard/sales-chart", "host": ["{{base_url}}"], "path": ["api", "dashboard", "sales-chart"] }
          }
        }
      ]
    },
    {
      "name": "🔔 Notifications",
      "item": [
        {
          "name": "12. Mes notifications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/notifications", "host": ["{{base_url}}"], "path": ["api", "notifications"] }
          }
        }
      ]
    }
  ]
}
